APP_NAME="Sistema PEI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# --- APP_URL ---
# Informe a URL completa de acesso ao sistema, incluindo protocolo, host e
# subdiretorio publico caso o projeto esteja em uma subpasta do servidor web.
# Exemplo Apache com subpasta: http://192.168.1.10/fs-v1/public
# Exemplo porta padrao sem subpasta: http://meu-servidor.gov.br
#
# ATENCAO - LIVEWIRE: o Livewire realiza requisicoes AJAX de volta ao servidor
# usando esta URL como base. Se ela nao refletir exatamente o endereco pelo qual
# o navegador acessa o sistema (incluindo qualquer subpasta), as requisicoes de
# componentes reativos falharao com erros 404 ou 419. Mantenha sempre em
# sincronia com o VirtualHost ou alias configurado no Apache/Nginx.
APP_URL=

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Banco de Dados (PostgreSQL) ---
# O projeto usa multiplos schemas. O search_path esta em config/database.php.
# Apos clonar, crie o banco e execute: php artisan migrate --seed
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=nome_do_banco
DB_USERNAME=seu_usuario
DB_PASSWORD=sua_senha

# --- Sessao ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# --- SESSION_DOMAIN ---
# Informe apenas o HOST (sem protocolo, sem porta, sem subpasta).
# Exemplos: 192.168.1.10 | meu-servidor.gov.br | localhost
#
# ATENCAO - LIVEWIRE: o cookie de sessao e vinculado a este dominio. Se o valor
# nao corresponder ao host pelo qual o navegador acessa o sistema, o Laravel nao
# consegue ler a sessao nas requisicoes AJAX do Livewire, gerando erros 419
# (CSRF token mismatch) ou comportamentos de autenticacao inesperados. Nao
# inclua o protocolo (http/https) nem o caminho (/fs-v1/public) aqui - somente
# o host puro, identico ao que aparece na barra de endereco do navegador.
SESSION_DOMAIN=

# --- Filas / Cache ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# --- Memcached (opcional) ---
MEMCACHED_HOST=127.0.0.1

# --- Redis (opcional - o projeto usa database por padrao) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- E-mail ---
# Para desenvolvimento recomenda-se Mailtrap (mailtrap.io) ou driver log.
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=seu_usuario_mailtrap
MAIL_PASSWORD=sua_senha_mailtrap
MAIL_FROM_ADDRESS="noreply@sua-organizacao.gov.br"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS S3 (opcional - nao utilizado por padrao) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"