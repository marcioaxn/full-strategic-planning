APP_NAME="Sistema PEI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/fs-v1/public

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Banco de Dados (PostgreSQL) ---
# O projeto usa multiplos schemas. O search_path esta em config/database.php.
# Apos clonar, crie o banco e execute: php artisan migrate --seed
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=nome_do_banco
DB_USERNAME=seu_usuario
DB_PASSWORD=sua_senha

# --- Sessao ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

# --- Filas / Cache ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# --- Memcached (opcional) ---
MEMCACHED_HOST=127.0.0.1

# --- Redis (opcional - o projeto usa database por padrao) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- E-mail ---
# Para desenvolvimento recomenda-se Mailtrap (mailtrap.io) ou driver log.
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=seu_usuario_mailtrap
MAIL_PASSWORD=sua_senha_mailtrap
MAIL_FROM_ADDRESS="noreply@sua-organizacao.gov.br"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS S3 (opcional - nao utilizado por padrao) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"